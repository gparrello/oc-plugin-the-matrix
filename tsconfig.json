{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "strict": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "index.ts"
  ]
}
