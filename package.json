{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-the-matrix",
  "version": "0.2.0",
  "description": "Matrix-inspired TUI rain, intro, and theme for OpenCode.",
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "homepage": "https://github.com/gparrello/oc-plugin-the-matrix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gparrello/oc-plugin-the-matrix.git"
  },
  "bugs": {
    "url": "https://github.com/gparrello/oc-plugin-the-matrix/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tui",
    "matrix",
    "theme"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc --project tsconfig.json && node ./scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/index.js",
    "./theme": "./dist/matrix-console.json"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "opencode": ">=1.3.13"
  }
}
